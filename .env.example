# Planfect — environment variables.
# Copy to `.env` and fill in. NEVER commit real keys. Service-role / provider keys are used
# ONLY in Supabase Edge Functions (server-side), never shipped in the iOS app.

# ---- Supabase ----
SUPABASE_URL=
SUPABASE_ANON_KEY=                 # safe for the app (RLS-guarded)
SUPABASE_SERVICE_ROLE_KEY=         # Edge Functions only — bypasses RLS; keep secret

# ---- LLM provider selection (see docs/AI_PROVIDERS.md) ----
ACTIVE_LLM_PROVIDER=openai         # openai | anthropic | qwen
PLANNER_MODEL=gpt-5.4              # e.g. gpt-5.4 | gpt-4.1 | claude-opus-4-8 | qwen-max

# ---- Provider API keys (server-side only) ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
QWEN_API_KEY=                      # Alibaba DashScope
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ---- Maps provider (see docs/DECISIONS.md ADR-006) ----
MAPS_PROVIDER=apple                # apple | google | amap
APPLE_MAPS_TOKEN=                  # Apple Maps Server API token
# GOOGLE_MAPS_API_KEY=
# AMAP_KEY=                        # 高德, for China
